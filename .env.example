# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------
ENV=production
API_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=zlttbots
DB_USER=zlttbots
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# -----------------------------------------------------------------------------
# Cache / queue
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Execution / platform integrations
# -----------------------------------------------------------------------------
PLATFORM_API_BASE=https://api.partner.example
PLATFORM_API_KEY=
HTTP_TIMEOUT=10

# -----------------------------------------------------------------------------
# Guardrails / throttling
# -----------------------------------------------------------------------------
RATE_TOKENS=60
RATE_MAX_TOKENS=120
RATE_REFILL_PER_SEC=1
DEFAULT_DAILY_SPEND_LIMIT=100.0

# -----------------------------------------------------------------------------
# Rendering defaults (CPU-safe baseline)
# -----------------------------------------------------------------------------
FFMPEG_HWACCEL=none
FFMPEG_CPU_PRESET=veryfast
FFMPEG_CPU_CRF=23

# -----------------------------------------------------------------------------
# Model sync / artifact storage
# -----------------------------------------------------------------------------
MODEL_BUCKET=zlttbots-models
MODEL_SYNC_OBJECT_KEY=model-service/latest-model.pt
S3_ENDPOINT=http://minio:9000

# -----------------------------------------------------------------------------
# Federated / distributed controls
# -----------------------------------------------------------------------------
FEDERATION_SECRET=REPLACE_WITH_STRONG_FEDERATION_SECRET
FEDERATION_TOKEN_TTL=900
PEER_ALLOWLIST=
PROMETHEUS_METRICS_ENABLED=true
RETRAINING_INTERVAL_SECONDS=3600
RL_AGENT_1_ALPHA=0.1
RL_AGENT_2_ALPHA=0.1

# -----------------------------------------------------------------------------
# Security / app secrets
# -----------------------------------------------------------------------------
JWT_SECRET=REPLACE_WITH_32_CHAR_MIN_SECRET
INTERNAL_SERVICE_TOKEN=REPLACE_WITH_SHARED_INTERNAL_TOKEN
AFFILIATE_WEBHOOK_SECRET=change-me

# -----------------------------------------------------------------------------
# Payments
# -----------------------------------------------------------------------------
STRIPE_KEY=REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_PRO_PRICE_ID=REPLACE_WITH_STRIPE_PRICE_ID
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_STRIPE_WEBHOOK_SECRET
